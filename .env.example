# Supabase is optional for local mode. Add these values for accounts and cloud persistence.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Python vision service. Keep the API key identical in both terminals.
VISION_SERVICE_URL=http://127.0.0.1:8000
VISION_API_KEY=replace-with-a-long-random-value
VISION_MAX_UPLOAD_MB=25
VISION_PROXY_MAX_UPLOAD_MB=4
VISION_REQUEST_TIMEOUT_MS=170000
