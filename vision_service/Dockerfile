FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PORT=8000

RUN apt-get update \
    && apt-get install -y --no-install-recommends tesseract-ocr libglib2.0-0 libgl1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY vision_service/requirements.txt /app/vision_service/requirements.txt
RUN pip install --no-cache-dir -r /app/vision_service/requirements.txt
COPY vision_service /app/vision_service

EXPOSE 8000
CMD ["sh", "-c", "python -m uvicorn vision_service.app.main:app --host 0.0.0.0 --port ${PORT}"]
