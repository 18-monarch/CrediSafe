VISION_API_KEY=replace-with-a-long-random-value
VISION_ALLOWED_ORIGINS=http://localhost:3000
VISION_MAX_UPLOAD_MB=25
VISION_SAMPLE_INTERVAL_SECONDS=0.4
VISION_MAX_SAMPLED_FRAMES=180
VISION_DETECT_MAX_WIDTH=1280
VISION_MAX_CANDIDATES_PER_FRAME=3
VISION_MIN_FRAME_SHARPNESS=18
VISION_OCR_TIMEOUT_SECONDS=2.5

# Included general road-object model.
VISION_OBJECT_MODEL_PATH=vision_service/models/yolov8n.pt
VISION_OBJECT_CONFIDENCE=0.28
VISION_OBJECT_IMAGE_SIZE=640

# Optional dedicated helmet model. Leave empty until a validated model is added.
VISION_HELMET_MODEL_PATH=
VISION_HELMET_CONFIDENCE=0.35
VISION_HELMET_IMAGE_SIZE=640
